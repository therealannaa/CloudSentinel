# === AWS / LocalStack ===
LOCALSTACK_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=ap-south-1
APPROVED_REGIONS=ap-south-1

# === LLM backend for the arms (A1-A3) ===
# Pick ONE. Selection order: LLM_BASE_URL > GEMINI_API_KEY > deterministic (offline).
#
# Option A — Local Ollama (free, no quota, reproducible). Recommended.
#   ollama serve & ; ollama pull llama3.1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1
# LLM_PROVIDER=ollama          # optional label shown in run output
# LLM_TIMEOUT=180              # local models can be slow; seconds per call
#
# (LLM_BASE_URL also works for Groq/OpenRouter/GitHub Models — just change the URL,
#  key, and model.)
#
# Option B — Google Gemini (leave LLM_BASE_URL unset to use this).
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-1.5-flash

ABUSEIPDB_KEY=your-abuseipdb-key-here
VIRUSTOTAL_KEY=your-virustotal-key-here

# === Infrastructure ===
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
SLACK_WEBHOOK_URL=

# === Database ===
DB_PATH=cloudsentinel.db

# === Risk Thresholds ===
RISK_CRITICAL=75
RISK_HIGH=50
MTTD_TARGET=300

# === Collector Settings ===
ZEEK_LOG_PATH=data/conn.log
PORT_SCAN_THRESHOLD=20
EXFIL_THRESHOLD_MB=100
MASS_DOWNLOAD_THRESHOLD=50
BULK_DELETE_THRESHOLD=20
EPHEMERAL_INSTANCE_THRESHOLD=600
